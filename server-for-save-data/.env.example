# Primary Next.js origin (no trailing slash). Any http(s)://localhost:* or 127.0.0.1:* is also allowed for local dev.
CLIENT_URL=http://localhost:3000

# Port for this server (optional; default 5002)
PORT=5002

# Next.js: point save-order / orders API here (optional; defaults to http://localhost:5002).
# Include the scheme, e.g. http://localhost:5002 — not "localhost:5002" alone.
# NEXT_PUBLIC_ORDERS_SAVE_BACKEND_URL=http://localhost:5002

# Writes under ./data/orders/*.json (gitignored).
