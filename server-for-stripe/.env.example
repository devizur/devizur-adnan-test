# Stripe (Dashboard → Developers → API keys)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...

# Used for CORS, checkout success/cancel URLs (no trailing slash)
CLIENT_URL=http://localhost:3000

# If 5000 is busy, the server tries 5001, 5002, … or set an explicit free port:
PORT=5000

# Optional: Stripe CLI → `stripe listen --forward-to localhost:5000/webhook`
# STRIPE_WEBHOOK_SECRET=whsec_...
