# Stripe (Dashboard → Developers → API keys)
STRIPE_SECRET_KEY=sk_test_...
# Same publishable key in the Next app as NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY (.env.local)
STRIPE_PUBLISHABLE_KEY=pk_test_...

# Used for CORS, checkout success/cancel URLs (no trailing slash)
CLIENT_URL=http://localhost:3000

# Default matches the Next app env NEXT_PUBLIC_STRIPE_BACKEND_URL (http://localhost:5002)
PORT=5002

# Optional: Stripe CLI → `stripe listen --forward-to localhost:5000/webhook`
# STRIPE_WEBHOOK_SECRET=whsec_...

# Paid orders from POST /save-order are written to ./data/orders/*.json (gitignored).
